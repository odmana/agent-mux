{
  "name": "agent-mux-electron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/bundle.mjs",
  "scripts": {
    "dev": "tsc && electron dist/main.js",
    "build": "tsc",
    "bundle": "esbuild dist/main.js --bundle --platform=node --format=esm --outfile=dist/bundle.mjs --external:node-pty --external:electron --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\"",
    "dist": "electron-builder"
  },
  "dependencies": {
    "agent-mux-server": "workspace:*",
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "electron": "41.2.0",
    "electron-builder": "26.8.1",
    "esbuild": "0.28.0",
    "typescript": "6.0.2"
  },
  "build": {
    "appId": "com.agentmux.app",
    "productName": "agent-mux",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/bundle.mjs"
    ],
    "extraResources": [
      {
        "from": "../client/dist",
        "to": "client-dist"
      }
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.png"
    },
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ]
  }
}
